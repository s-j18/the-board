# Upstash Redis (get from upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Transfermarkt API (your self-hosted instance URL)
TRANSFERMARKT_API_URL=https://transfermarkt-api.fly.dev

# PartyKit (auto-filled after deploy, leave blank for local dev)
NEXT_PUBLIC_PARTYKIT_HOST=

# Your deployed app URL (for PartyKit CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000
